---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout
  title="Blog — Mustafa Toker"
  description="Long-form writing on SEO systems, marketing automation, and developer tooling."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">Blog</h1>
      <p class="text-gray-400 text-lg">
        Long-form writing on SEO systems, marketing automation, and the tools that power modern growth.
      </p>
    </div>

    {posts.length === 0 ? (
      <div class="border border-gray-800 rounded-xl p-16 flex flex-col items-center justify-center text-center">
        <p class="text-gray-500">No posts yet. Check back soon.</p>
      </div>
    ) : (
      <ul class="space-y-8">
        {posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.id}`}
              class="group block border border-gray-800 hover:border-gray-700 rounded-xl p-6 transition-colors duration-200"
            >
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.map((tag) => (
                  <span class="text-xs font-medium text-indigo-400 bg-indigo-950 px-2 py-0.5 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="text-xl font-semibold text-white group-hover:text-indigo-300 transition-colors duration-200 mb-2">
                {post.data.title}
              </h2>
              <p class="text-gray-400 text-sm leading-relaxed mb-4">
                {post.data.description}
              </p>
              <time class="text-xs text-gray-600" datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>
