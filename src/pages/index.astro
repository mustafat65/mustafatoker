---
// Ana sayfa — Hero, Featured Sections
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Mustafa Toker — Marketing Systems & Developer Tools"
  description="I help marketers and developers build smarter systems. Explore my blog, tools, and curated resources."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-20 sm:pt-32 sm:pb-28">
      <div class="max-w-3xl">
        <!-- Üst etiket -->
        <div class="inline-flex items-center gap-2 bg-indigo-950 text-indigo-400 text-xs font-semibold px-3 py-1.5 rounded-full mb-6 border border-indigo-800">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
          Marketing & Dev Systems
        </div>

        <!-- Ana başlık -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-tight mb-6">
          I help marketers &amp; developers build
          <span class="text-indigo-400"> smarter systems</span>
        </h1>

        <!-- Kısa bio -->
        <p class="text-lg sm:text-xl text-gray-400 leading-relaxed mb-10 max-w-2xl">
          I'm Mustafa — a marketing technologist exploring the intersection of SEO, automation, and developer tooling.
          I write about systems that scale, share tools I actually use, and curate resources worth your time.
        </p>

        <!-- CTA butonları -->
        <div class="flex flex-wrap gap-4">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
          >
            Read Blog
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/tools"
            class="inline-flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors border border-gray-700"
          >
            See Tools
          </a>
        </div>
      </div>
    </div>

    <!-- Arka plan dekoratif gradient -->
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-indigo-900/20 rounded-full blur-3xl translate-x-1/3 -translate-y-1/3"></div>
    </div>
  </section>

  <!-- Ayırıcı çizgi -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <hr class="border-gray-800" />
  </div>

  <!-- Featured Sections — Blog, Tools, Resources -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <h2 class="text-2xl font-bold text-white mb-10">Explore</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Blog kartı -->
      <a
        href="/blog"
        class="group bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-gray-700 rounded-xl p-6 transition-all"
      >
        <div class="w-10 h-10 bg-indigo-900/60 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h3 class="text-white font-semibold text-lg mb-2 group-hover:text-indigo-400 transition-colors">Blog</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Long-form writing on SEO systems, marketing automation, and the tools that power them.
        </p>
        <span class="inline-flex items-center gap-1 text-indigo-400 text-sm mt-4 font-medium">
          Read articles
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </a>

      <!-- Tools kartı -->
      <a
        href="/tools"
        class="group bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-gray-700 rounded-xl p-6 transition-all"
      >
        <div class="w-10 h-10 bg-emerald-900/60 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 class="text-white font-semibold text-lg mb-2 group-hover:text-emerald-400 transition-colors">Tools</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Free web tools I built for SEO analysis, WordPress audits, and AI prompt workflows.
        </p>
        <span class="inline-flex items-center gap-1 text-emerald-400 text-sm mt-4 font-medium">
          Browse tools
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </a>

      <!-- Resources kartı -->
      <a
        href="/resources"
        class="group bg-gray-900 hover:bg-gray-800 border border-gray-800 hover:border-gray-700 rounded-xl p-6 transition-all"
      >
        <div class="w-10 h-10 bg-amber-900/60 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
          </svg>
        </div>
        <h3 class="text-white font-semibold text-lg mb-2 group-hover:text-amber-400 transition-colors">Resources</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Curated links, templates, and references across SEO, development, and marketing automation.
        </p>
        <span class="inline-flex items-center gap-1 text-amber-400 text-sm mt-4 font-medium">
          View resources
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </a>
    </div>
  </section>
</Layout>
