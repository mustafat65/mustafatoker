---
// Blog listesi — içerik eklenene kadar "coming soon" durumu
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Blog — Mustafa Toker"
  description="Long-form writing on SEO systems, marketing automation, and developer tooling."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Sayfa başlığı -->
    <div class="mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">Blog</h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        Long-form writing on SEO systems, marketing automation, and the tools that power modern growth.
      </p>
    </div>

    <!-- Coming soon durumu -->
    <div class="border border-gray-800 rounded-xl p-16 flex flex-col items-center justify-center text-center">
      <div class="w-14 h-14 bg-gray-900 rounded-full flex items-center justify-center mb-5">
        <svg class="w-7 h-7 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold text-white mb-2">Coming Soon</h2>
      <p class="text-gray-500 max-w-sm">
        Articles are being drafted. Check back soon — or follow on Twitter to get notified when the first post drops.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 text-indigo-400 hover:text-indigo-300 text-sm font-medium"
      >
        <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
        Back to Home
      </a>
    </div>
  </div>
</Layout>
